# Copy this file to .env and adjust values as needed.
# docker-compose.yml environment: block already sets sensible Docker defaults,
# so you only need .env for local (non-Docker) development.

# Path to the tracker CSV when running the backend locally (not in Docker).
# Defaults to the bundled sample; point to your real tracker CSV when you have one.
CSV_PATH=data/job_applications_sample.csv

# SQLite path for local dev. Leave as-is; the file will be created automatically.
DATABASE_URL=sqlite:///./app.db

# Comma-separated list of skills to show when none are parsed from application notes.
DEFAULT_MISSING_SKILLS=Kubernetes,Redis,GraphQL,Cypress,Terraform,CI/CD

# Comma-separated allowed CORS origins. Use * for local dev only.
# Example for production: CORS_ORIGINS=http://localhost:3000,https://myapp.example.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=false

# Optional API key for write/execute endpoints. Leave empty to keep write endpoints open.
WRITE_API_KEY=

# Discovery integration. Paths are resolved relative to the app/ folder.
DISCOVERY_SCRIPT_PATH=discovery/job_finder.py
# DISCOVERY_CV_PATH must be set to your CV file path before /run-discovery will work.
# DISCOVERY_CV_PATH=/absolute/path/to/your/CV.tex
DISCOVERY_API_BASE_URL=http://127.0.0.1:8000
DISCOVERY_LOG_MAX_CHARS=3000
