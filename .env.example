DISCOVERY_LOG_MAX_CHARS=3000
DISCOVERY_DEFAULT_PROFILE=de

APPLICATIONS_ROOT=applications
VACANCIES_TEMPLATE_DIR=vacancies/_template
BASE_CV_TEMPLATE_PATH=resumes/CV.tex
