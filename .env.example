# Copy to .env and override only what you need.

# ---------- Core app ----------

# When running via docker compose, leave this unset — compose sets it to the named volume path.
# For local development without Docker: sqlite:///./app.db
DATABASE_URL=sqlite:///./app.db
DEFAULT_MISSING_SKILLS=Kubernetes,Redis,GraphQL,Cypress,Terraform,CI/CD
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
CORS_ALLOW_CREDENTIALS=false
WRITE_API_KEY=
REQUIRE_WRITE_KEY=true
GENERATED_DOCUMENT_AUTHOR=

# ---------- Discovery runtime ----------
# Required for discovery unless each /run-discovery request sends cv_path.
# Example: applications/resumes/CV.tex
DISCOVERY_CV_PATH=

# Backend API base URL used by discovery to upsert shortlist rows.
DISCOVERY_API_BASE_URL=http://127.0.0.1:8000

# Default profile when request omits profile: de | swe | other
DISCOVERY_DEFAULT_PROFILE=de

# Optional local override file for discovery-engine defaults.
# Example: discovery/discovery_config.override.json
DISCOVERY_CONFIG_PATH=

# ---------- Optional LLM reranker ----------
# Use either OPENAI_API_KEY or LLM_API_KEY.
OPENAI_API_KEY=
LLM_API_KEY=
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ---------- Workspace paths ----------
# Paths below are relative to repo root unless absolute.
APPLICATIONS_ROOT=applications
VACANCIES_TEMPLATE_DIR=vacancies/_template
BASE_CV_TEMPLATE_PATH=resumes/CV.tex
